---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---

<details class="group bg-white border border-brand-border p-5 rounded-xl [&_summary::-webkit-details-marker]:hidden transition-all duration-300 open:border-brand-pink/30 shadow-sm">
  <summary class="flex justify-between items-center cursor-pointer focus:outline-none">
    <h3 class="text-base font-bold text-brand-charcoal group-open:text-brand-pink transition-colors tracking-wide pr-4">
      {question}
    </h3>
    <span class="text-brand-pink group-open:rotate-180 transition-transform duration-300 text-sm">
      ▼
    </span>
  </summary>
  <p class="mt-4 text-sm text-zinc-600 leading-relaxed border-t border-brand-border pt-4">
    {answer}
  </p>
</details>

