---
const posts = [
  { image: "/images/lashes_service.png", link: "https://www.instagram.com/p/lashes1", likes: "124" },
  { image: "/images/brows_service.png", link: "https://www.instagram.com/p/brows2", likes: "89" },
  { image: "/images/skincare_service.png", link: "https://www.instagram.com/p/skin3", likes: "142" },
  { image: "/images/before_after_eye.png", link: "https://www.instagram.com/p/wax4", likes: "95" },
];
---

<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
  {posts.map(post => (
    <a 
      href={post.link} 
      target="_blank" 
      rel="noopener noreferrer" 
      class="group relative aspect-square rounded-xl overflow-hidden border border-brand-border block shadow-sm hover:border-brand-pink/30 hover:shadow-md transition-all duration-300"
    >
      <img src={post.image} alt="Instagram Post" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
      <!-- Hover overlay details -->
      <div class="absolute inset-0 bg-brand-pink/70 opacity-0 group-hover:opacity-100 flex items-center justify-center transition-opacity duration-300 z-10">
        <span class="text-white font-bold tracking-widest text-xs uppercase flex items-center gap-1.5">
          ❤️ {post.likes} Likes
        </span>
      </div>
    </a>
  ))}
</div>

