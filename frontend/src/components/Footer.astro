---
import { useTranslations } from "../i18n/utils";

interface Props {
  lang?: "en" | "es";
}

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
---
<footer class="bg-brand-dark border-t border-brand-gold/20 pt-16 pb-8 text-zinc-400">
  <div class="container-custom grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
    <!-- Brand Pillar -->
    <div class="space-y-4">
      <img src="/logo.png" alt="Lashes & MGlamour Logo" class="h-20 w-auto object-contain mb-2 brightness-0 invert transition-transform duration-300 hover:scale-105" />
      <p class="text-sm leading-relaxed">
        {t("footer.tagline")}
      </p>
    </div>

    <!-- Opening Hours -->
    <div class="space-y-4">
      <h3 class="font-heading text-lg text-brand-gold tracking-wide">{t("footer.hours")}</h3>
      <ul class="space-y-2 text-sm">
        <li class="flex justify-between"><span>{lang === "es" ? "Lunes - Sábado:" : "Monday - Saturday:"}</span> <span>9:00 AM - 8:00 PM</span></li>
        <li class="flex justify-between"><span>{lang === "es" ? "Domingo:" : "Sunday:"}</span> <span class="text-brand-gold font-semibold">{lang === "es" ? "Cerrado" : "Closed"}</span></li>
      </ul>
    </div>

    <!-- Contact & NAP info -->
    <div class="space-y-4">
      <h3 class="font-heading text-lg text-brand-gold tracking-wide">{lang === "es" ? "Contáctanos" : "Contact Us"}</h3>
      <address class="not-italic space-y-2 text-sm">
        <p>📍 {t("bar.address")}</p>
        <p class="flex flex-col space-y-1">
          <span>📞 <a href="tel:+17864606580" class="hover:text-brand-pink transition-colors">+1 (786) 460-6580</a></span>
          <span>📞 <a href="tel:+13058330302" class="hover:text-brand-pink transition-colors">+1 (305) 833-0302</a></span>
        </p>
        <p>✉️ <a href="mailto:info@lashesmglamour.com" class="hover:text-brand-pink transition-colors">info@lashesmglamour.com</a></p>
      </address>
    </div>

    <!-- Quick Links -->
    <div class="space-y-4">
      <h3 class="font-heading text-lg text-brand-gold tracking-wide">{t("footer.quickLinks")}</h3>
      <nav class="grid grid-cols-2 gap-2 text-sm">
        <a href={lang === "es" ? "/es" : "/"} class="hover:text-brand-pink transition-colors">{t("nav.home")}</a>
        <a href={lang === "es" ? "/es/services" : "/services"} class="hover:text-brand-pink transition-colors">{t("nav.services")}</a>
        <a href={lang === "es" ? "/es/about" : "/about"} class="hover:text-brand-pink transition-colors">{t("nav.about")}</a>
        <a href={lang === "es" ? "/es/gallery" : "/gallery"} class="hover:text-brand-pink transition-colors">{t("nav.gallery")}</a>
        <a href={lang === "es" ? "/es/blog" : "/blog"} class="hover:text-brand-pink transition-colors">{t("nav.blog")}</a>
        <a href={lang === "es" ? "/es/faq" : "/faq"} class="hover:text-brand-pink transition-colors">{t("nav.faq")}</a>
      </nav>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="container-custom border-t border-zinc-800 pt-8 text-center text-xs flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
    <p>&copy; {new Date().getFullYear()} Lashes & MGlamour. {t("footer.rights")}</p>
    <div class="flex space-x-6">
      <a href="https://www.instagram.com/lashesmglamour" class="hover:text-brand-pink transition-colors" aria-label="Follow us on Instagram">Instagram</a>
      <a href="https://www.facebook.com/lashesmglamour" class="hover:text-brand-pink transition-colors" aria-label="Like us on Facebook">Facebook</a>
      <a href="https://www.tiktok.com/@lashes_mglamour" class="hover:text-brand-pink transition-colors" aria-label="Follow us on TikTok">TikTok</a>
      <a href={lang === "es" ? "/es/privacy" : "/privacy"} class="hover:text-brand-pink transition-colors">{lang === "es" ? "Política de Privacidad" : "Privacy Policy"}</a>
    </div>
  </div>
</footer>

