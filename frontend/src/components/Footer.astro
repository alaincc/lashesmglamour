---
---
<footer class="bg-brand-grey-dark border-t border-brand-gold/10 pt-16 pb-8">
  <div class="container-custom grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
    <!-- Brand Pillar -->
    <div class="space-y-4">
      <img src="/logo.png" alt="Lashes & MGlamour Logo" class="h-12 w-auto object-contain mb-2" />
      <p class="text-sm text-brand-grey-muted leading-relaxed">
        Premium lash extensions, brow mapping, facials, and skincare services in Miami. We deliver luxury beauty services tailored to enhance your natural glamour.
      </p>
    </div>

    <!-- Opening Hours -->
    <div class="space-y-4">
      <h3 class="font-heading text-lg text-brand-gold tracking-wide">Hours of Operation</h3>
      <ul class="space-y-2 text-sm text-brand-grey-muted">
        <li class="flex justify-between"><span>Monday - Saturday:</span> <span>9:00 AM - 8:00 PM</span></li>
        <li class="flex justify-between"><span>Sunday:</span> <span class="text-brand-gold">Closed</span></li>
      </ul>
    </div>

    <!-- Contact & NAP info -->
    <div class="space-y-4">
      <h3 class="font-heading text-lg text-brand-gold tracking-wide">Contact Us</h3>
      <address class="not-italic space-y-2 text-sm text-brand-grey-muted">
        <p>📍 8700 SW 137th Ave, Miami, FL 33186</p>
        <p>📞 <a href="tel:+13055550199" class="hover:text-brand-gold transition-colors">+1 (305) 555-0199</a></p>
        <p>✉️ <a href="mailto:info@lashesmglamour.com" class="hover:text-brand-gold transition-colors">info@lashesmglamour.com</a></p>
      </address>
    </div>

    <!-- Quick Links -->
    <div class="space-y-4">
      <h3 class="font-heading text-lg text-brand-gold tracking-wide">Quick Navigation</h3>
      <nav class="grid grid-cols-2 gap-2 text-sm text-brand-grey-muted">
        <a href="/" class="hover:text-brand-gold transition-colors">Home</a>
        <a href="/services" class="hover:text-brand-gold transition-colors">Services</a>
        <a href="/about" class="hover:text-brand-gold transition-colors">About Us</a>
        <a href="/gallery" class="hover:text-brand-gold transition-colors">Gallery</a>
        <a href="/blog" class="hover:text-brand-gold transition-colors">Blog</a>
        <a href="/faq" class="hover:text-brand-gold transition-colors">FAQ</a>
      </nav>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="container-custom border-t border-brand-gold/5 pt-8 text-center text-xs text-brand-grey-muted flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
    <p>&copy; {new Date().getFullYear()} Lashes & MGlamour. All rights reserved.</p>
    <div class="flex space-x-6">
      <a href="https://www.instagram.com/lashesmglamour" class="hover:text-brand-gold transition-colors" aria-label="Follow us on Instagram">Instagram</a>
      <a href="https://www.facebook.com/lashesmglamour" class="hover:text-brand-gold transition-colors" aria-label="Like us on Facebook">Facebook</a>
      <a href="/privacy" class="hover:text-brand-gold transition-colors">Privacy Policy</a>
    </div>
  </div>
</footer>
