---
const benefits = [
  {
    title: "Certified Specialists",
    description: "Our aestheticians are fully licensed, highly trained, and passionate about crafting the perfect look for you.",
    icon: `<svg class="w-8 h-8 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
    </svg>`
  },
  {
    title: "Premium Products",
    description: "We use only medical-grade adhesives and ultra-soft silk lashes that protect your natural lash health.",
    icon: `<svg class="w-8 h-8 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
    </svg>`
  },
  {
    title: "Clean & Sterilized Tools",
    description: "Your health is our priority. We maintain hospital-grade sanitation standards for every single tool and station.",
    icon: `<svg class="w-8 h-8 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
    </svg>`
  },
  {
    title: "Custom Mapping",
    description: "Every set of lashes and brow shape is mapped individually to complement your unique eye shape and symmetry.",
    icon: `<svg class="w-8 h-8 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L16 4m0 13V4m0 0L9 7"/>
    </svg>`
  },
  {
    title: "Cozy & Relaxing",
    description: "Unwind on our ultra-comfortable heated lash beds in a calm, soothing atmosphere with relaxing music.",
    icon: `<svg class="w-8 h-8 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
    </svg>`
  }
];
---

<section class="py-24 bg-brand-light-pink border-t border-b border-brand-border">
  <div class="container-custom">
    <!-- Header -->
    <div class="text-center space-y-4 max-w-xl mx-auto mb-16">
      <span class="text-xs font-bold uppercase tracking-widest text-brand-pink block">Our Core Pillars</span>
      <h2 class="font-heading text-3xl sm:text-4xl text-brand-charcoal font-bold">Why Choose Lashes & MGlamour</h2>
      <p class="font-script text-brand-pink text-3xl normal-case font-normal block leading-none">Your Beauty. Our Passion.</p>
    </div>

    <!-- Benefits Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-8">
      {benefits.map(benefit => (
        <div class="bg-white p-6 rounded-xl border border-brand-border/40 shadow-sm flex flex-col items-center text-center space-y-4 transition-transform hover:-translate-y-1">
          <!-- Icon Circle -->
          <div class="p-3 bg-brand-light-pink rounded-full flex items-center justify-center border border-brand-pink/5" fragment set:html={benefit.icon}>
          </div>
          <!-- Title & Description -->
          <h3 class="font-heading font-semibold text-brand-charcoal text-base">{benefit.title}</h3>
          <p class="text-xs text-zinc-500 leading-relaxed">{benefit.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
