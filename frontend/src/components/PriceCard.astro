---
interface Props {
  name: string;
  price: string;
  duration?: string;
}

const { name, price, duration } = Astro.props;
---

<div class="flex items-baseline justify-between border-b border-brand-border pb-3">
  <div class="space-y-1 pr-4">
    <span class="text-sm sm:text-base font-semibold text-brand-charcoal tracking-wide">{name}</span>
    {duration && <p class="text-xs text-zinc-500">⏱️ {duration}</p>}
  </div>
  <div class="flex-grow border-b border-dotted border-brand-pink/20 mx-2 h-1 min-w-[20px]"></div>
  <span class="text-brand-pink font-bold text-sm sm:text-base tracking-wider whitespace-nowrap">{price}</span>
</div>

