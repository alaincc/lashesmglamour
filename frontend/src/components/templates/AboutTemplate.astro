---
import Layout from "../../layouts/Layout.astro";

interface Props {
  lang?: "en" | "es";
}

const { lang = "en" } = Astro.props;

const texts = {
  en: {
    title: "About Us | Lashes & MGlamour",
    philosophy: "Our Philosophy",
    heading: "About Lashes & MGlamour",
    subheading: "Delivering luxury care",
    sanctuary: "Luxe Salon Sanctuary",
    p1: "Founded with the vision of offering high-end, personalized lash mapping and skincare services, Lashes & MGlamour has become Miami's go-to beauty sanctuary.",
    p2: "Our expert aestheticians work exclusively with premium-grade materials and customize every lash extension application matching the natural shape of your eyes, ensuring safety, comfort, and breathtaking beauty.",
    testimonial: '"The best lash extensions salon in Kendall! The atmosphere is incredibly luxurious, the staff are professional, and my volume lash set lasts for weeks without issues."',
    client: "— Valerie D., Client"
  },
  es: {
    title: "Sobre Nosotros | Lashes & MGlamour",
    philosophy: "Nuestra Filosofía",
    heading: "Sobre Lashes & MGlamour",
    subheading: "Brindando un cuidado de lujo",
    sanctuary: "Santuario de Salón de Lujo",
    p1: "Fundado con la visión de ofrecer servicios personalizados y de alta gama en diseño de pestañas y cuidado de la piel, Lashes & MGlamour se ha convertido en el santuario de belleza preferido de Miami.",
    p2: "Nuestras esteticistas expertas trabajan exclusivamente con materiales de primera calidad y personalizan cada aplicación de extensión de pestañas adaptándose a la forma natural de tus ojos, garantizando seguridad, comodidad y una belleza impresionante.",
    testimonial: '"¡El mejor salón de extensiones de pestañas en Kendall! El ambiente es increíblemente lujoso, el personal es profesional y mis pestañas de volumen duran semanas sin problemas."',
    client: "— Valerie D., Cliente"
  }
};

const pageText = texts[lang];
---
<Layout title={pageText.title} lang={lang}>
  <section class="py-24 bg-white">
    <div class="container-custom max-w-4xl mx-auto space-y-12">
      <!-- Heading block -->
      <div class="text-center space-y-4 mb-16">
        <span class="text-xs font-bold uppercase tracking-widest text-brand-pink block">{pageText.philosophy}</span>
        <h1 class="font-heading text-4xl text-brand-charcoal font-bold">{pageText.heading}</h1>
        <p class="font-script text-brand-pink text-3xl normal-case font-normal block leading-none">{pageText.subheading}</p>
      </div>

      <!-- Main Copy Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div class="space-y-6">
          <h2 class="font-heading text-2xl text-brand-pink font-bold">{pageText.sanctuary}</h2>
          <p class="text-sm text-zinc-600 leading-relaxed">
            {pageText.p1}
          </p>
          <p class="text-sm text-zinc-600 leading-relaxed">
            {pageText.p2}
          </p>
        </div>
        <div class="rounded-2xl overflow-hidden border border-brand-border aspect-[4/5] max-w-[320px] mx-auto shadow-md">
          <img src="/images/hero_model.png" alt="Inside Lashes & MGlamour Studio" class="w-full h-full object-cover" />
        </div>
      </div>

      <!-- Testimonial citation -->
      <div class="bg-brand-light-pink p-8 rounded-2xl text-center max-w-2xl mx-auto space-y-4 border border-brand-pink/10 italic shadow-sm">
        <p class="text-sm text-zinc-600 leading-relaxed">
          {pageText.testimonial}
        </p>
        <span class="text-xs font-bold uppercase tracking-widest text-brand-pink not-italic block font-semibold">{pageText.client}</span>
      </div>
    </div>
  </section>
</Layout>
