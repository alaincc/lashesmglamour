---
import Layout from "../../layouts/Layout.astro";

interface Props {
  lang?: "en" | "es";
}

const { lang = "en" } = Astro.props;

const texts = {
  en: {
    title: "Contact & Location | Lashes & MGlamour",
    badge: "Get in Touch",
    heading: "Contact & Location",
    subheading: "We'd love to hear from you",
    reachOut: "Reach Out to Us",
    description: "Have questions about our lash mappings, services, or bookings? Feel free to contact our support coordinators via phone, email, or by visiting our location in Kendall.",
    shiftsTitle: "Working Shifts",
    monSat: "Monday - Saturday:",
    sun: "Sunday:",
    closed: "Closed",
    studioName: "Lashes & MGlamour Kendall",
    mapsBtn: "Open Google Maps →"
  },
  es: {
    title: "Contacto y Ubicación | Lashes & MGlamour",
    badge: "Ponte en Contacto",
    heading: "Contacto y Ubicación",
    subheading: "Nos encantaría saber de ti",
    reachOut: "Comunícate con Nosotros",
    description: "¿Tienes preguntas sobre nuestros diseños de pestañas, servicios o reservas? No dudes en contactar a nuestros coordinadores de soporte por teléfono, correo electrónico o visitando nuestro local en Kendall.",
    shiftsTitle: "Horarios de Atención",
    monSat: "Lunes - Sábado:",
    sun: "Domingo:",
    closed: "Cerrado",
    studioName: "Lashes & MGlamour Kendall",
    mapsBtn: "Abrir Google Maps →"
  }
};

const pageText = texts[lang];
---
<Layout title={pageText.title} lang={lang}>
  <section class="py-24 bg-white">
    <div class="container-custom max-w-4xl mx-auto space-y-12">
      <!-- Heading block -->
      <div class="text-center space-y-4 mb-16">
        <span class="text-xs font-bold uppercase tracking-widest text-brand-pink block">{pageText.badge}</span>
        <h1 class="font-heading text-4xl text-brand-charcoal font-bold">{pageText.heading}</h1>
        <p class="font-script text-brand-pink text-3xl normal-case font-normal block leading-none">{pageText.subheading}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <!-- Contact details -->
        <div class="space-y-8">
          <h2 class="font-heading text-2xl text-brand-pink font-bold">{pageText.reachOut}</h2>
          <p class="text-sm text-zinc-600 leading-relaxed">
            {pageText.description}
          </p>

          <address class="not-italic space-y-4 text-sm text-zinc-600">
            <p class="flex items-center gap-3">📍 <span>4095 SW 137th Ave #3, Miami, FL 33175</span></p>
            <p class="flex items-center gap-3">
              📞 
              <span>
                <a href="tel:+17864606580" class="hover:text-brand-pink text-brand-pink font-bold transition-colors">+1 (786) 460-6580</a>
                <span class="text-zinc-300 mx-2">|</span>
                <a href="tel:+13058330302" class="hover:text-brand-pink text-brand-pink font-bold transition-colors">+1 (305) 833-0302</a>
              </span>
            </p>
            <p class="flex items-center gap-3">✉️ <span><a href="mailto:info@lashesmglamour.com" class="hover:text-brand-pink text-brand-pink font-bold transition-colors">info@lashesmglamour.com</a></span></p>
          </address>

          <!-- Opening hours summary -->
          <div class="border-t border-brand-border pt-6 space-y-3">
            <h3 class="font-heading text-lg text-brand-pink font-bold">{pageText.shiftsTitle}</h3>
            <p class="text-sm text-zinc-600 flex justify-between max-w-xs">
              <span>{pageText.monSat}</span> <span>9:00 AM - 8:00 PM</span>
            </p>
            <p class="text-sm text-zinc-600 flex justify-between max-w-xs">
              <span>{pageText.sun}</span> <span class="text-brand-pink font-semibold">{pageText.closed}</span>
            </p>
          </div>
        </div>

        <!-- Google Maps container -->
        <div class="bg-brand-light-pink rounded-2xl overflow-hidden h-[350px] border border-brand-pink/10 shadow-sm relative">
          <!-- Google map mock iframe -->
          <div class="absolute inset-0 bg-brand-light-pink flex items-center justify-center text-center p-6 space-y-4 flex-col">
            <span class="text-3xl">📍</span>
            <div>
              <h3 class="font-bold text-brand-charcoal text-base">{pageText.studioName}</h3>
              <p class="text-xs text-zinc-500 mt-1">4095 SW 137th Ave #3, Miami, FL 33175</p>
            </div>
            <a href="https://maps.google.com" target="_blank" class="bg-brand-pink text-white text-xs font-bold uppercase py-2.5 px-6 rounded transition-colors hover:bg-brand-pink-hover shadow-lg shadow-brand-pink/20 hover:scale-[1.02]">
              {pageText.mapsBtn}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
