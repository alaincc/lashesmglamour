---
interface Props {
  beforeImage: string;
  afterImage: string;
  title: string;
  description?: string;
}

const { beforeImage, afterImage, title, description } = Astro.props;
const isSingleImage = beforeImage === afterImage;
---

<div class="bg-white border border-brand-border/50 p-4 rounded-xl space-y-4 shadow-sm">
  {isSingleImage ? (
    <div class="relative rounded-lg overflow-hidden aspect-square border border-brand-border/40">
      <img src={beforeImage} alt={title} class="w-full h-full object-cover" />
    </div>
  ) : (
    <div class="grid grid-cols-2 gap-2 relative rounded-lg overflow-hidden aspect-video border border-brand-border/40">
      <div class="relative">
        <img src={beforeImage} alt={`${title} Before`} class="w-full h-full object-cover" />
        <span class="absolute top-2 left-2 bg-brand-charcoal/70 px-2 py-0.5 rounded text-[10px] uppercase font-bold tracking-widest text-zinc-300">
          Before
        </span>
      </div>
      <div class="relative">
        <img src={afterImage} alt={`${title} After`} class="w-full h-full object-cover" />
        <span class="absolute top-2 right-2 bg-brand-pink text-white px-2 py-0.5 rounded text-[10px] uppercase font-bold tracking-widest">
          After
        </span>
      </div>
    </div>
  )}

  <div class="text-center md:text-left space-y-1">
    <h3 class="font-heading text-base font-bold text-brand-charcoal tracking-wide">{title}</h3>
    {description && <p class="text-xs text-zinc-500">{description}</p>}
  </div>
</div>

