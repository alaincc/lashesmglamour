---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
}

const {
  title = "Lashes & MGlamour | Premium Lash Extensions & Brows Miami",
  description = "Discover Miami's premier beauty studio. Professional Classic, Hybrid, and Volume lash extensions, brow shaping, and skin care services. Book your appointment online.",
  canonical = "https://lashesmglamour.com",
  image = "/designs/logo/logo.png",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="bg-brand-black text-brand-ivory font-body">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonical} />

    <!-- Title and Description -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonical} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@200;300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />

    <!-- Structured Data (LocalBusiness) -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "BeautySalon",
        "name": "Lashes & MGlamour",
        "image": "https://lashesmglamour.com/designs/logo/logo.png",
        "@id": "https://lashesmglamour.com/#salon",
        "url": "https://lashesmglamour.com",
        "telephone": "+13055550199",
        "priceRange": "$$",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "8700 SW 137th Ave",
          "addressLocality": "Miami",
          "addressRegion": "FL",
          "postalCode": "33186",
          "addressCountry": "US"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 25.6888,
          "longitude": -80.4172
        },
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
            "opens": "09:00",
            "closes": "20:00"
          }
        ],
        "sameAs": [
          "https://www.instagram.com/lashesmglamour",
          "https://www.facebook.com/lashesmglamour"
        ]
      }
    </script>

    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>

    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-XXXXXXX');
    </script>

    <!-- Meta Pixel Code -->
    <script is:inline>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', 'XXXXXXXXXXXXXXX');
      fbq('track', 'PageView');
    </script>
  </head>
  <body class="min-h-screen flex flex-col justify-between overflow-x-hidden selection:bg-brand-gold selection:text-brand-black pb-16 md:pb-0">
    <!-- Google Tag Manager (noscript fallback) -->
    <noscript>
      <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-XXXXXXX" height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>

    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />

    <!-- CRO WhatsApp Click-to-Chat Floating Button -->
    <a 
      href="https://wa.me/13055550199?text=Hello%21%20I%20would%20like%20to%20ask%20about%20your%20lash%20extensions%20appointment%20slots." 
      target="_blank" 
      rel="noopener noreferrer" 
      class="fixed bottom-20 right-6 z-40 bg-[#25D366] hover:bg-[#128C7E] text-white p-3.5 rounded-full shadow-2xl transition-all duration-300 hover:scale-105 flex items-center justify-center border border-white/10"
      aria-label="Chat with Lashes & MGlamour on WhatsApp"
    >
      <svg class="h-6 w-6 fill-current" viewBox="0 0 24 24">
        <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.835-4.113c1.558.924 3.42 1.411 5.316 1.412 5.586.002 10.134-4.542 10.138-10.13.002-2.707-1.05-5.253-2.962-7.168C17.472 2.083 14.921.986 12.21.986c-5.59 0-10.136 4.543-10.141 10.134-.002 1.957.513 3.868 1.492 5.548l-1.02 3.722 3.818-1.002c1.597.87 3.393 1.328 5.197 1.329zM16.633 13.7c-.266-.134-1.58-.78-1.824-.868-.243-.088-.42-.133-.596.133-.176.265-.68.868-.832 1.042-.152.176-.305.198-.572.065-.266-.134-1.127-.415-2.147-1.327-.79-.705-1.324-1.577-1.48-1.842-.155-.266-.017-.41.115-.543.12-.118.266-.31.4-.464.133-.155.176-.265.266-.442.088-.176.044-.33-.022-.464-.066-.134-.596-1.436-.816-1.966-.215-.518-.432-.446-.596-.446-.154-.002-.33-.002-.507-.002-.176 0-.464.066-.707.33-.243.265-.928.906-.928 2.21s.95 2.562 1.082 2.74c.133.176 1.87 2.854 4.53 4.004.633.273 1.127.436 1.513.56.636.202 1.213.174 1.67.106.509-.077 1.58-.645 1.802-1.237.22-.592.22-1.1.155-1.237-.066-.137-.243-.223-.509-.356z"/>
      </svg>
    </a>

    <!-- Mobile Sticky Book Now CTA footer -->
    <div class="fixed bottom-0 left-0 right-0 z-40 bg-brand-grey-dark/95 backdrop-blur-md border-t border-brand-gold/20 p-3 flex md:hidden items-center justify-between shadow-2xl">
      <div>
        <span class="text-xs text-brand-gold font-bold uppercase tracking-wider block">Reserve online</span>
        <span class="text-[10px] text-brand-grey-muted">Secure your slot in under 3 clicks</span>
      </div>
      <a href="/book" class="bg-brand-gold hover:bg-brand-champagne text-brand-black font-bold uppercase tracking-wider text-xs px-5 py-2.5 rounded-brand transition-colors shadow-gold">
        Book Now
      </a>
    </div>
  </body>
</html>
