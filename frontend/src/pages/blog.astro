---
import Layout from "../layouts/Layout.astro";

const posts = [
  { title: "The Ultimate Eyelash Extensions Aftercare Guide", excerpt: "Learn how to clean, brush, and protect your lash extensions to make them last up to 6 weeks.", date: "2026-06-25", category: "Lashes" },
  { title: "Everything You Need to Know About Brow Lamination", excerpt: "Discover how brow lamination relaxes brow hairs to give you a thick, fluffy look without daily styling.", date: "2026-06-22", category: "Brows" },
  { title: "Daily Skincare Routines for Summer in Miami", excerpt: "Professional tips to hydrate your skin and prevent sunscreen build-up during hot Florida months.", date: "2026-06-18", category: "Skin Care" },
];
---

<Layout title="Beauty Blog & Tips | Lashes & MGlamour">
  <section class="py-24 bg-brand-black">
    <div class="container-custom max-w-4xl mx-auto space-y-16">
      
      <!-- Heading block -->
      <div class="text-center space-y-4 max-w-xl mx-auto">
        <span class="text-xs font-bold uppercase tracking-widest text-brand-gold">Beauty Tips & News</span>
        <h1 class="font-heading text-4xl text-brand-ivory">The MGlamour Blog</h1>
        <p class="text-sm text-brand-grey-muted leading-relaxed">
          Stay up to date with the latest trends in eyelash extension mapping, brow styling, facials, and beauty routines.
        </p>
      </div>

      <!-- Blog post lists -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {posts.map(post => (
          <div class="glass-card p-6 rounded-lg flex flex-col justify-between hover:border-brand-gold/20 transition-all duration-300">
            <div class="space-y-4">
              <span class="text-[10px] font-bold uppercase tracking-widest text-brand-gold bg-brand-gold/5 border border-brand-gold/10 px-2 py-0.5 rounded">
                {post.category}
              </span>
              <h2 class="font-heading text-lg font-semibold text-brand-ivory leading-tight hover:text-brand-gold transition-colors">
                {post.title}
              </h2>
              <p class="text-xs text-brand-grey-muted leading-relaxed line-clamp-3">
                {post.excerpt}
              </p>
            </div>
            <div class="mt-6 pt-4 border-t border-brand-gold/5 flex justify-between items-center text-[10px] text-brand-grey-muted">
              <span>📅 {post.date}</span>
              <a href="#" class="text-brand-gold hover:text-brand-champagne font-bold uppercase transition-colors">
                Read More &rarr;
              </a>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>
</Layout>
