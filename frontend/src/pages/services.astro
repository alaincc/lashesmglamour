---
import Layout from "../layouts/Layout.astro";
import ServiceCard from "../components/ServiceCard.astro";

// Static fallback list to ensure compile is robust even if API is starting
const servicesFallback = [
  { id: "var_classic_full", name: "Classic Lash Extensions Full Set", description: "One single premium extension applied to each natural lash. Extremely natural look.", price_cents: 12000, duration_minutes: 90 },
  { id: "var_hybrid_full", name: "Hybrid Lash Extensions Full Set", description: "Blend of classic and volume extensions. Texturized and fuller look.", price_cents: 14000, duration_minutes: 100 },
  { id: "var_volume_full", name: "Volume Lash Extensions Full Set", description: "Lightweight fans applied to each natural lash. Fluffy and full glamour set.", price_cents: 16000, duration_minutes: 120 },
  { id: "var_brow_lam", name: "Brow Lamination & Shaping", description: "Relaxes and shapes brow hairs for a fuller, brushed-up symmetrical look.", price_cents: 8500, duration_minutes: 45 },
  { id: "var_skincare_facial", name: "Luxe Rejuvenating Facial", description: "Deep hydration treatment utilizing premium hyaluronic serums.", price_cents: 11000, duration_minutes: 60 },
  { id: "var_wax_brow", name: "Brow Wax & Threading", description: "Precision hair removal for a clean and sleek definition.", price_cents: 3500, duration_minutes: 20 },
];
---

<Layout title="Luxe Services Menu | Lashes & MGlamour">
  <section class="py-24 bg-brand-black relative">
    <div class="container-custom">
      
      <!-- Heading block -->
      <div class="text-center space-y-4 max-w-xl mx-auto mb-16">
        <span class="text-xs font-bold uppercase tracking-widest text-brand-gold">Service Catalog</span>
        <h1 class="font-heading text-4xl text-brand-ivory">Signature Beauty Treatments</h1>
        <p class="text-sm text-brand-grey-muted leading-relaxed">
          Explore our premium mapping sets, brow shapings, and skincare options. All booking prices are synchronized directly with our Square account.
        </p>
      </div>

      <!-- Services List Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {servicesFallback.map(service => (
          <ServiceCard
            id={service.id}
            name={service.name}
            description={service.description}
            price_cents={service.price_cents}
            duration_minutes={service.duration_minutes}
          />
        ))}
      </div>

      <!-- Booking CTA banner -->
      <div class="mt-20 glass-card p-8 rounded-lg max-w-3xl mx-auto text-center space-y-6 border border-brand-gold/10">
        <h2 class="font-heading text-2xl text-brand-gold">Ready to secure your slot?</h2>
        <p class="text-sm text-brand-grey-muted max-w-lg mx-auto">
          Apppointments book quickly. Select your service, technician, and desired date time slots in our secure wizard.
        </p>
        <a href="/book" class="inline-block bg-brand-gold hover:bg-brand-champagne text-brand-black font-bold uppercase tracking-wider text-xs px-8 py-3.5 rounded-brand transition-colors shadow-gold">
          Book Appointment Now
        </a>
      </div>

    </div>
  </section>
</Layout>
