---
import Layout from "../layouts/Layout.astro";
import BrandHero from "../components/BrandHero.astro";
import BeforeAfter from "../components/BeforeAfter.astro";
import PriceCard from "../components/PriceCard.astro";
import GoogleReviews from "../components/GoogleReviews.astro";
import InstagramFeed from "../components/InstagramFeed.astro";
import WhyChooseUs from "../components/WhyChooseUs.astro";

// Static price lists for featured beauty items
const featuredServices = [
  { name: "Classic Lash Extensions Full Set", price: "$120.00", duration: "90 mins" },
  { name: "Hybrid Lash Extensions Full Set", price: "$140.00", duration: "100 mins" },
  { name: "Volume Lash Extensions Full Set", price: "$160.00", duration: "120 mins" },
  { name: "Brow Lamination & Shaping", price: "$85.00", duration: "45 mins" },
];
---

<Layout title="Lashes & MGlamour | Luxe Lash Extensions & Brows Miami">
  <!-- Hero Section -->
  <BrandHero />

  <!-- Services highlights -->
  <section class="py-24 bg-white border-b border-brand-border">
    <div class="container-custom">
      <div class="text-center space-y-4 max-w-xl mx-auto mb-16">
        <span class="text-xs font-bold uppercase tracking-widest text-brand-pink block">Our Menu Highlights</span>
        <h2 class="font-heading text-3xl sm:text-4xl text-brand-charcoal font-bold">Popular Luxe Services</h2>
        <p class="text-sm text-zinc-500 leading-relaxed">
          Select from our signature mapping variants designed to showcase your natural assets.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {featuredServices.map(service => (
          <PriceCard name={service.name} price={service.price} duration={service.duration} />
        ))}
      </div>

      <div class="text-center pt-12">
        <a href="/services" class="inline-flex items-center gap-2 border border-brand-pink/30 hover:border-brand-pink text-brand-pink font-bold uppercase tracking-wider text-xs px-8 py-3.5 rounded transition-all hover:bg-brand-pink/5">
          View All Services &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Why Choose Us Pillars -->
  <WhyChooseUs />

  <!-- Before & After Portfolio Section -->
  <section class="py-24 bg-white">
    <div class="container-custom">
      <div class="text-center space-y-4 max-w-xl mx-auto mb-16">
        <span class="text-xs font-bold uppercase tracking-widest text-brand-pink block">Visual Portfolio</span>
        <h2 class="font-heading text-3xl sm:text-4xl text-brand-charcoal font-bold">Real Client Transformations</h2>
        <p class="text-sm text-zinc-500 leading-relaxed">
          See the mapping results of our premium volume extensions and brow restorations.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <BeforeAfter 
          beforeImage="/images/before_after_eye.png" 
          afterImage="/images/before_after_eye.png" 
          title="Volume Lash Extensions" 
          description="Symmetric, full volume lash restoration"
        />
        <BeforeAfter 
          beforeImage="/images/brows_service.png" 
          afterImage="/images/brows_service.png" 
          title="Brow Lamination & Tint" 
          description="Symmetric brow shape definition"
        />
        <BeforeAfter 
          beforeImage="/images/skincare_service.png" 
          afterImage="/images/skincare_service.png" 
          title="Premium Facial Care" 
          description="Deep cleansing skin treatment"
        />
      </div>
    </div>
  </section>

  <!-- Google Reviews Testimonials Section -->
  <section class="py-24 bg-brand-light-pink border-t border-b border-brand-border">
    <div class="container-custom">
      <div class="text-center space-y-4 max-w-xl mx-auto mb-16">
        <span class="text-xs font-bold uppercase tracking-widest text-brand-pink block">Reviews Feed</span>
        <h2 class="font-heading text-3xl sm:text-4xl text-brand-charcoal font-bold">What Our Clients Say</h2>
        <p class="text-sm text-zinc-500 leading-relaxed">
          Read top-rated five-star reviews shared directly from our Google business page profile.
        </p>
      </div>

      <GoogleReviews />
    </div>
  </section>

  <!-- Instagram Social Feed Section -->
  <section class="py-24 bg-white">
    <div class="container-custom">
      <div class="text-center space-y-4 max-w-xl mx-auto mb-16">
        <span class="text-xs font-bold uppercase tracking-widest text-brand-pink block">Social Portfolio</span>
        <h2 class="font-heading text-3xl sm:text-4xl text-brand-charcoal font-bold">Follow Us on Instagram</h2>
        <p class="text-sm text-zinc-500 leading-relaxed">
          Stay connected for promotional discounts, style updates, and lash care advice at <a href="https://instagram.com/lashesmglamour" target="_blank" class="text-brand-pink font-bold hover:underline">@lashesmglamour</a>.
        </p>
      </div>

      <InstagramFeed />
    </div>
  </section>
</Layout>

