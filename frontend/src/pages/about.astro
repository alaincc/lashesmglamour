---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About Us | Lashes & MGlamour">
  <section class="py-24 bg-brand-black">
    <div class="container-custom max-w-4xl mx-auto space-y-12">
      <!-- Heading block -->
      <div class="text-center space-y-4 mb-12">
        <span class="text-xs font-bold uppercase tracking-widest text-brand-gold">Our Philosophy</span>
        <h1 class="font-heading text-4xl text-brand-ivory">About Lashes & MGlamour</h1>
      </div>

      <!-- Main Copy Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div class="space-y-6">
          <h2 class="font-heading text-2xl text-brand-gold">Delivering Luxury Care</h2>
          <p class="text-sm text-brand-grey-muted leading-relaxed">
            Founded with the vision of offering high-end, personalized lash mapping and skincare services, **Lashes & MGlamour** has become Miami's go-to beauty sanctuary.
          </p>
          <p class="text-sm text-brand-grey-muted leading-relaxed">
            Our expert aestheticians work exclusively with premium-grade materials and customize every lash extension application matching the natural shape of your eyes, ensuring safety, comfort, and breathtaking beauty.
          </p>
        </div>
        <div class="rounded-lg overflow-hidden border border-brand-gold/10 aspect-[4/5] max-w-[320px] mx-auto shadow-2xl">
          <img src="/designs/website/aboutus.png" alt="Inside Lashes & MGlamour Studio" class="w-full h-full object-cover" />
        </div>
      </div>

      <!-- Testimonial citation -->
      <div class="glass-card p-8 rounded-lg text-center max-w-2xl mx-auto space-y-4 border border-brand-gold/5 italic">
        <p class="text-sm text-brand-grey-muted">
          "The best lash extensions salon in Kendall! The atmosphere is incredibly luxurious, the staff are professional, and my volume lash set lasts for weeks without issues."
        </p>
        <span class="text-xs font-bold uppercase tracking-widest text-brand-gold not-italic block">— Valerie D., Client</span>
      </div>
    </div>
  </section>
</Layout>
