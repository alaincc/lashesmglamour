---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About Us | Lashes & MGlamour">
  <section class="py-24 bg-white">
    <div class="container-custom max-w-4xl mx-auto space-y-12">
      <!-- Heading block -->
      <div class="text-center space-y-4 mb-16">
        <span class="text-xs font-bold uppercase tracking-widest text-brand-pink block">Our Philosophy</span>
        <h1 class="font-heading text-4xl text-brand-charcoal font-bold">About Lashes & MGlamour</h1>
        <p class="font-script text-brand-pink text-3xl normal-case font-normal block leading-none">Delivering luxury care</p>
      </div>

      <!-- Main Copy Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div class="space-y-6">
          <h2 class="font-heading text-2xl text-brand-pink font-bold">Luxe Salon Sanctuary</h2>
          <p class="text-sm text-zinc-600 leading-relaxed">
            Founded with the vision of offering high-end, personalized lash mapping and skincare services, **Lashes & MGlamour** has become Miami's go-to beauty sanctuary.
          </p>
          <p class="text-sm text-zinc-600 leading-relaxed">
            Our expert aestheticians work exclusively with premium-grade materials and customize every lash extension application matching the natural shape of your eyes, ensuring safety, comfort, and breathtaking beauty.
          </p>
        </div>
        <div class="rounded-2xl overflow-hidden border border-brand-border aspect-[4/5] max-w-[320px] mx-auto shadow-md">
          <img src="/images/hero_model.png" alt="Inside Lashes & MGlamour Studio" class="w-full h-full object-cover" />
        </div>
      </div>

      <!-- Testimonial citation -->
      <div class="bg-brand-light-pink p-8 rounded-2xl text-center max-w-2xl mx-auto space-y-4 border border-brand-pink/10 italic shadow-sm">
        <p class="text-sm text-zinc-600 leading-relaxed">
          "The best lash extensions salon in Kendall! The atmosphere is incredibly luxurious, the staff are professional, and my volume lash set lasts for weeks without issues."
        </p>
        <span class="text-xs font-bold uppercase tracking-widest text-brand-pink not-italic block font-semibold">— Valerie D., Client</span>
      </div>
    </div>
  </section>
</Layout>
