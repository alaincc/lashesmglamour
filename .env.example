# -----------------------------------------------------------------------------
# Lashes & MGlamour Environment Variables Template
# Copy this file to '.env' and populate the fields with your credentials.
# -----------------------------------------------------------------------------

# --- Square Configurations ---
# Environment to run Square requests: 'sandbox' or 'production'
SQUARE_ENVIRONMENT=sandbox

# Official Sandbox/Production Credentials from the Square Developer Dashboard
SQUARE_APPLICATION_ID=sandbox-sq0idp-XXXXXXXXXXXXXXXXXXXXXX
SQUARE_ACCESS_TOKEN=sandbox-sq0atb-XXXXXXXXXXXXXXXXXXXXXX
SQUARE_LOCATION_ID=L-XXXXXXXXXXXXXXXXXXXXXX

# Signature key provided by Square when setting up webhook listeners
SQUARE_WEBHOOK_SIGNATURE=webhook_sig_XXXXXXXXXXXXXXXXXXXXXX

# --- Backend Database Credentials ---
# In docker-compose, PostgreSQL configurations default to:
POSTGRES_USER=admin
POSTGRES_PASSWORD=luxe_secure_pass
POSTGRES_DB=lashes_db

# --- Security and Admin Details ---
# Secret key used to sign JWT session cookies
SECRET_KEY=luxe_super_secure_secret_key_change_me_in_production

# Custom admin credentials for logging into the dashboard
ADMIN_USERNAME=admin
# Use python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('password'))" to generate a hash
ADMIN_PASSWORD_HASH=$2b$12$EixZaYVK1fsYi1FnQsOgleJ9o.Edf0w7nI96W5E.1/U2d2z2c.W4W

# --- SMTP Configurations ---
# The address of your SMTP server (e.g. smtp.gmail.com)
SMTP_HOST=
# The port of your SMTP server (587 for TLS, 465 for SSL)
SMTP_PORT=587
# The username of your SMTP email account
SMTP_USER=
# The password of your SMTP email account or app-specific password
SMTP_PASSWORD=
# The sender email address
EMAILS_FROM_EMAIL=reserva@lashesmglamour.com
# The sender name
EMAILS_FROM_NAME="Lashes & MGlamour"

